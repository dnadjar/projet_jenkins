pipeline {
    agent any

    // Utilisation des outils configurés dans "Global Tool Configuration" [cite: 5, 18]
    tools {
        maven 'Maven3'
        jdk   'JDK17'
    }

    parameters {
        string(name: 'BRANCH', defaultValue: 'main', description: 'Branche Git à builder') [cite: 6]
        choice(name: 'ENVIRONMENT', choices: ['dev', 'staging', 'prod'], description: 'Environnement cible')
        booleanParam(name: 'SKIP_TESTS', defaultValue: false, description: 'Ignorer les tests') [cite: 7]
    }

    stages {
        // ── Stage 1 : Récupérer le code ──────────────
        stage('Checkout') {
            steps {
                checkout scm [cite: 8]
            }
        }

        // ── Stage 2 : Compilation ────────────────────
        stage('Build') {
            steps {
                dir('ICDE848') { // Entre dans le sous-dossier [cite: 9]
                    bat 'mvn clean compile -B' // bat pour Windows [cite: 9]
                }
            }
        }

        // ── Stage 3 : Tests unitaires ────────────────
        stage('Tests unitaires') {
            when { not { expression { return params.SKIP_TESTS } } } [cite: 10]
            steps {
                dir('ICDE848') {
                    bat 'mvn test -B' [cite: 11]
                }
            }
            post {
                always {
                    // Publie les rapports de tests [cite: 12]
                    junit 'ICDE848/target/surefire-reports/*.xml'
                }
            }
        }

        // ── Stage 4 : Tests d'intégration ────────────
        stage('Tests intégration') {
            when { not { expression { return params.SKIP_TESTS } } } [cite: 13]
            steps {
                dir('ICDE848') {
                    bat 'mvn verify -Dsurefire.skip=true -B' [cite: 14]
                }
            }
            post {
                always {
                    junit 'ICDE848/target/failsafe-reports/*.xml'
                }
            }
        }

        // ── Stage 5 : Couverture JaCoCo ──────────────
        stage('Couverture JaCoCo') {
            steps {
                dir('ICDE848') {
                    bat 'mvn jacoco:report -B' [cite: 15]
                }
            }
            post {
                always {
                    jacoco(
                        execPattern:   'ICDE848/target/jacoco.exec',
                        classPattern:  'ICDE848/target/classes',
                        sourcePattern: 'ICDE848/src/main/java',
                        minimumLineCoverage: '70' [cite: 16, 17]
                    )
                }
            }
        }

        // ── Stage 6 : Analyse qualité ────────────────
        stage('Qualité') {
            steps {
                dir('ICDE848') {
                    // Commande Maven groupée pour Windows [cite: 18, 19]
                    bat 'mvn checkstyle:checkstyle pmd:pmd pmd:cpd spotbugs:spotbugs -B'
                }
            }
            post {
                always {
                    recordIssues(
                        enabledForFailure: true,
                        tools: [
                            checkStyle(pattern: 'ICDE848/target/checkstyle-result.xml'), [cite: 21]
                            pmd(pattern:        'ICDE848/target/pmd.xml'), // Correction ici
                            cpd(pattern:        'ICDE848/target/cpd.xml'),
                            spotBugs(pattern:   'ICDE848/target/spotbugsXml.xml') [cite: 22]
                        ],
                        qualityGates: [[threshold: 10, type: 'TOTAL', unstable: true]] [cite: 23, 24]
                    )
                }
            }
        }

        // ── Stage 7 : Archiver le JAR ────────────────
        stage('Archive') {
            steps {
                dir('ICDE848') {
                    archiveArtifacts artifacts: 'target/*.jar', fingerprint: true [cite: 25]
                }
                echo "Artefact archivé avec succès" [cite: 26]
            }
        }
    }

    post {
        always {
            echo "Pipeline terminée — statut : ${currentBuild.currentResult}" [cite: 30]
        }
        failure {
            echo "Le build a échoué." [cite: 31]
        }
    }
}