/**
 * Jenkinsfile – Pipeline CI complète
 * Projet : Boutique en ligne – ICDE848
 *
 * Ce fichier doit être placé à la RACINE du dépôt Git.
 * Jenkins le détecte automatiquement lors de la création du job Pipeline.
 *
 * Stages :
 *   1. Checkout       → récupère le code depuis Git
 *   2. Build          → compile le code source
 *   3. Tests unitaires → lance *Test.java via Surefire
 *   4. Tests intégration → lance *IT.java via Failsafe
 *   5. Couverture     → génère le rapport JaCoCo
 *   6. Qualité        → Checkstyle + PMD + CPD + SpotBugs
 *   7. Archive        → sauvegarde le JAR dans Jenkins
 *
 * Post :
 *   - failure → email à l'équipe
 *   - fixed   → email quand le build repasse au vert
 */

pipeline {
    agent any

    // Utilisation des noms exacts configurés dans Jenkins [cite: 5, 29, 30]
    tools {
        maven 'Maven3'
        jdk   'JDK17'
    }

    parameters {
        string(name: 'BRANCH', defaultValue: 'main', description: 'Branche Git à builder')
        choice(name: 'ENVIRONMENT', choices: ['dev', 'staging', 'prod'], description: 'Environnement cible')
        booleanParam(name: 'SKIP_TESTS', defaultValue: false, description: 'Ignorer les tests')
    }

    stages {
        // Stage 1 : Récupérer le code [cite: 8]
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        // Stage 2 : Compilation (On entre dans le sous-dossier) [cite: 9]
        stage('Build') {
            steps {
                dir('ICDE848') {
                    bat 'mvn clean compile -B'
                }
            }
        }

        // Stage 3 : Tests unitaires [cite: 10, 11]
        stage('Tests unitaires') {
            when { not { expression { return params.SKIP_TESTS } } }
            steps {
                dir('ICDE848') {
                    bat 'mvn test -B'
                }
            }
            post {
                always {
                    junit 'ICDE848/target/surefire-reports/*.xml' [cite: 12]
                }
            }
        }

        // Stage 4 : Tests d'intégration [cite: 13, 14]
        stage('Tests intégration') {
            when { not { expression { return params.SKIP_TESTS } } }
            steps {
                dir('ICDE848') {
                    bat 'mvn verify -Dsurefire.skip=true -B'
                }
            }
            post {
                always {
                    junit 'ICDE848/target/failsafe-reports/*.xml' [cite: 15]
                }
            }
        }

        // Stage 5 : Couverture de code [cite: 16]
        stage('Couverture JaCoCo') {
            steps {
                dir('ICDE848') {
                    bat 'mvn jacoco:report -B'
                }
            }
            post {
                always {
                    jacoco(
                        execPattern:   'ICDE848/target/jacoco.exec',
                        classPattern:  'ICDE848/target/classes',
                        sourcePattern: 'ICDE848/src/main/java',
                        minimumLineCoverage: '70' [cite: 17]
                    )
                }
            }
        }

        // Stage 6 : Analyse qualité (Checkstyle, PMD, SpotBugs) [cite: 18, 19]
        stage('Qualité') {
            steps {
                dir('ICDE848') {
                    // Commande groupée pour Windows
                    bat 'mvn checkstyle:checkstyle pmd:pmd pmd:cpd spotbugs:spotbugs -B'
                }
            }
            post {
                always {
                    recordIssues(
                        enabledForFailure: true,
                        tools: [
                            checkStyle(pattern: 'ICDE848/target/checkstyle-result.xml'), [cite: 21]
                            pmdParser(pattern:  'ICDE848/target/pmd.xml'), [cite: 21]
                            cpd(pattern:        'ICDE848/target/cpd.xml'), [cite: 21]
                            spotBugs(pattern:   'ICDE848/target/spotbugsXml.xml') [cite: 22]
                        ],
                        qualityGates: [[threshold: 10, type: 'TOTAL', unstable: true]] [cite: 23, 24]
                    )
                }
            }
        }

        // Stage 7 : Archive [cite: 25]
        stage('Archive') {
            steps {
                archiveArtifacts artifacts: 'ICDE848/target/*.jar', fingerprint: true
                echo "Artefact archivé avec succès" [cite: 26]
            }
        }
    }

    post {
        always {
            echo "Pipeline terminée — statut : ${currentBuild.currentResult}"
        }
        failure {
            echo "Le build a échoué. Vérifiez la configuration et les logs." [cite: 31, 32]
        }
    }
}