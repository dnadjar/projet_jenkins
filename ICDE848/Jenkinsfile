pipeline {
    agent any

    tools {
        maven 'Maven3'
        jdk   'JDK17'
    }

    parameters {
        string(name: 'BRANCH', defaultValue: 'main', description: 'Branche Git à builder')
        choice(name: 'ENVIRONMENT', choices: ['dev', 'staging', 'prod'], description: 'Environnement cible')
        booleanParam(name: 'SKIP_TESTS', defaultValue: false, description: 'Ignorer les tests')
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build') {
            steps {
                dir('ICDE848') {
                    bat 'mvn clean compile -B'
                }
            }
        }

        stage('Tests unitaires') {
            when { not { expression { return params.SKIP_TESTS } } }
            steps {
                dir('ICDE848') {
                    bat 'mvn test -B'
                }
            }
            post {
                always {
                    junit 'ICDE848/target/surefire-reports/*.xml'
                }
            }
        }

        stage('Tests intégration') {
            when { not { expression { return params.SKIP_TESTS } } }
            steps {
                dir('ICDE848') {
                    bat 'mvn verify -Dsurefire.skip=true -B'
                }
            }
            post {
                always {
                    junit 'ICDE848/target/failsafe-reports/*.xml'
                }
            }
        }

        stage('Couverture JaCoCo') {
            steps {
                dir('ICDE848') {
                    bat 'mvn jacoco:report -B'
                }
            }
            post {
                always {
                    jacoco(
                        execPattern:   'ICDE848/target/jacoco.exec',
                        classPattern:  'ICDE848/target/classes',
                        sourcePattern: 'ICDE848/src/main/java',
                        minimumLineCoverage: '70'
                    )
                }
            }
        }

        stage('Qualité') {
            steps {
                dir('ICDE848') {
                    bat 'mvn checkstyle:checkstyle pmd:pmd pmd:cpd spotbugs:spotbugs -B'
                }
            }
            post {
                always {
                    recordIssues(
                        enabledForFailure: true,
                        tools: [
                            checkStyle(pattern: 'ICDE848/target/checkstyle-result.xml'),
                            pmdParser(pattern: 'ICDE848/target/pmd.xml'),
                            cpd(pattern: 'ICDE848/target/cpd.xml'),
                            spotBugs(pattern: 'ICDE848/target/spotbugsXml.xml')
                        ],
                        qualityGates: [[threshold: 10, type: 'TOTAL', unstable: true]]
                    )
                }
            }
        }

        stage('Archive') {
            steps {
                dir('ICDE848') {
                    archiveArtifacts artifacts: 'target/*.jar', fingerprint: true
                }
            }
        }

        stage('Déclenchement Chaîné') {
            steps {
                echo "Appel du job de qualité secondaire..."
                // On déclenche le job B. wait: false permet de ne pas bloquer ce pipeline
                build job: 'boutique-qualite', wait: false
            }
        }
    }

    post {
        always {
            echo "Pipeline terminée — statut : ${currentBuild.currentResult}"
        }
        failure {
            emailext(
                subject: "FAILED: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
                body: "Le build a échoué. Consultez les logs ici : ${env.BUILD_URL}",
                to: 'ton.adresse@gmail.com', // REMPLACE PAR TON EMAIL
                attachLog: true
            )
        }
        fixed {
            emailext(
                subject: "FIXED: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
                body: "Le build est de nouveau stable : ${env.BUILD_URL}",
                to: 'damienencour2@gmail.com' // REMPLACE PAR TON EMAIL
            )
        }
    }
}
